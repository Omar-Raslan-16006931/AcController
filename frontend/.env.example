# Supabase project (Settings > API in the Supabase dashboard)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# FastAPI backend running on the Raspberry Pi. Use a Tailscale/Cloudflare
# Tunnel URL (recommended) or the Pi's LAN address, e.g. http://acpi.local:8000
VITE_API_BASE_URL=http://acpi.local:8000
